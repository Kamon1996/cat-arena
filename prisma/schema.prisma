generator client {
  provider = "prisma-client-js"
  // "native" → local dev (macOS/whatever). "debian-openssl-3.0.x" → the Docker
  // runtime (node:22-bookworm-slim, Debian 12 / OpenSSL 3) used for the VPS deploy,
  // so the query engine binary is generated for the container platform too.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (Neon PgBouncer) — runtime
  directUrl = env("DIRECT_URL") // direct (non-pooled) — migrations
}

// ─────────────────────────── Domain: Cats ───────────────────────────

model Cat {
  id         String     @id @default(cuid())
  slug       String     @unique // SEO URL: <name>-<nanoid>
  name       String // cat display name (UI + SEO)
  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id])
  status     CatStatus  @default(PENDING) // PENDING | ACTIVE | HIDDEN | BANNED
  // Glicko-2 — the CAT is rated, not an individual image
  rating     Float      @default(1500)
  rd         Float      @default(350)
  vol        Float      @default(0.06)
  score      Float      @default(800) // = rating - 2*rd (denormalized for sorting)
  wins       Int        @default(0)
  losses     Int        @default(0)
  draws      Int        @default(0) // reserved
  timesShown Int        @default(0)
  images     CatImage[]
  reports    Report[]
  orgs       CatOrg[]
  createdAt  DateTime   @default(now())
  approvedAt DateTime?
  lastRatedAt DateTime? // last vote that updated this cat's rating; drives RD-decay cron

  @@index([status, score]) // leaderboard
  @@index([status, rd]) // "needs data" pool for pairing + RD-decay
  @@index([ownerId]) // enforce ≤2 cats per user
}

model CatImage {
  id               String      @id @default(cuid())
  catId            String
  cat              Cat         @relation(fields: [catId], references: [id], onDelete: Cascade)
  r2Key            String // original; thumb/card derived by key convention
  sha256           String?     @unique // hex digest of the original bytes; null on legacy rows
  crop             Json? // applied duel framing {x,y,width,height} in rotation-baked px; null = uncropped
  width            Int // intrinsic (rotation-baked, UNCROPPED) dimensions
  height           Int
  position         Int         @default(0) // carousel order
  status           ImageStatus @default(PENDING) // moderation / NSFW at image level
  rejectionReasons String[]    @default([]) // moderator-selected reasons, set on REJECT
  createdAt        DateTime    @default(now())

  @@index([catId, position])
}

model Vote {
  id          String   @id @default(cuid())
  winnerCatId String // vote is BETWEEN cats
  loserCatId  String
  voterKey    String // anonId (cookie) or "user:<id>"
  createdAt   DateTime @default(now())

  @@index([voterKey, createdAt]) // seen-dedup / history
  @@index([winnerCatId])
  @@index([loserCatId])
}

model Report {
  // report against a cat
  id        String   @id @default(cuid())
  catId     String
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  reason    String?
  reporter  String // anonId / user
  createdAt DateTime @default(now())

  @@index([catId])
}

// ─────────────────────────── Domain: Organizations ───────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String   @unique // required, unique
  slug        String   @unique
  description String? // optional description
  logoR2Key   String? // optional logo (in R2)
  joinCode    String   @unique // long generated invite code
  createdById String   @unique // ≤1 org per user (unique creator)
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  members     CatOrg[]
}

model CatOrg {
  // membership + LOCAL Glicko-2 of a cat in an org
  catId      String
  orgId      String
  cat        Cat          @relation(fields: [catId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rating     Float        @default(1500)
  rd         Float        @default(350)
  vol        Float        @default(0.06)
  score      Float        @default(800) // org leaderboard sorts by score
  wins       Int          @default(0)
  losses     Int          @default(0)
  draws      Int          @default(0)
  timesShown Int          @default(0)
  joinedAt   DateTime     @default(now())

  @@id([catId, orgId])
  @@index([orgId, score]) // org leaderboard
}

enum CatStatus {
  PENDING
  ACTIVE
  HIDDEN
  BANNED
}

enum ImageStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// ─────────────────────── Auth.js (Prisma adapter) ────────────────────

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          Role          @default(USER) // USER | MODERATOR | ADMIN (RBAC gate for /admin)
  banned        Boolean       @default(false)
  bannedAt      DateTime?
  accounts      Account[]
  sessions      Session[]
  cats          Cat[] // owned cats (Cat.owner relation)
  organization  Organization? // ≤1 org per user (Organization.createdBy relation)
  createdAt     DateTime      @default(now())
}

model BannedEmail {
  id         String   @id @default(cuid())
  email      String   @unique
  reason     String?
  bannedById String? // admin who banned (informational, no FK)
  createdAt  DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
