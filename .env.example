# ── Postgres (Neon) ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/db?pgbouncer=true"   # pooled (runtime)
DIRECT_URL="postgresql://user:password@host/db"                    # direct (migrations)

# ── Auth.js v5 ───────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ── Resend magic-link email ──────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="cats@example.com"

# ── Cloudflare R2 (S3 API) ───────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="cat-arena"
R2_PUBLIC_URL="https://cdn.example.com"

# ── Upstash Redis (rate limiting) ────────────────────────────────
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# ── Pair-token HMAC ──────────────────────────────────────────────
PAIR_TOKEN_SECRET="generate-with-openssl-rand-base64-32"

# ── Cloudflare Workers AI (NSFW / is-it-a-cat) ───────────────────
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# ── PostHog (client analytics) ───────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── Sentry (errors / perf) ───────────────────────────────────────
SENTRY_DSN="https://xxxx@oXXXX.ingest.sentry.io/XXXX"
