# ── Postgres (Neon) ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/db?pgbouncer=true"   # pooled (runtime)
DIRECT_URL="postgresql://user:password@host/db"                    # direct (migrations)

# ── Auth.js v5 ───────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ── Resend magic-link email ──────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="cats@example.com"

# ── Object storage (S3 API) — defaults to Cloudflare R2 ──────────
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="cat-arena"
R2_PUBLIC_URL="https://cdn.example.com"           # CDN base URL for serving images
R2_ACCOUNT_ID=""                                  # used to derive the R2 endpoint if S3_ENDPOINT unset
# To migrate to Selectel/Yandex/MinIO — set these (no code change):
# S3_ENDPOINT="https://s3.ru-1.storage.selcloud.ru"
# S3_REGION="ru-1"                                # R2 uses "auto" (default)
# S3_FORCE_PATH_STYLE="true"                      # many non-R2 providers require this

# ── Redis: rate-limiting + pair-token nonce ──────────────────────
# Pick ONE driver:
#   REDIS_DRIVER=upstash → serverless HTTP (Vercel, current prod). Needs UPSTASH_* below.
#   REDIS_DRIVER=redis   → standard TCP (ioredis) for a persistent VPS. Needs REDIS_URL.
REDIS_DRIVER="upstash"
# driver=upstash:
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""
# driver=redis (VPS / docker-compose — points at the in-stack redis service):
# REDIS_URL="redis://redis:6379"

# ── Pair-token HMAC ──────────────────────────────────────────────
PAIR_TOKEN_SECRET="generate-with-openssl-rand-base64-32"

# ── Cloudflare Workers AI (NSFW / is-it-a-cat) ───────────────────
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# ── PostHog (client analytics) ───────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── Sentry (errors / perf) ───────────────────────────────────────
SENTRY_DSN="https://xxxx@oXXXX.ingest.sentry.io/XXXX"

# ── Cron (RD-decay + orphan cleanup) ─────────────────────────────
# Shared secret guarding /api/cron/*. Unset → cron endpoints disabled (503).
# Call as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="generate-with-openssl-rand-base64-32"

# ── Deploy (docker-compose on VPS only — not used on Vercel) ──────
# Domain Caddy obtains the TLS cert for and reverse-proxies to the app.
DOMAIN="cat-arena.ru"
